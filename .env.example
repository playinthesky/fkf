# ── fKF 정회원 포털 환경 변수 ────────────────────────────────────────────────
# 실제 값은 커밋하지 말고 배포 플랫폼의 환경 변수로 설정하세요.

# Flask 세션 서명 키 (운영에서는 반드시 임의의 긴 값으로)
SECRET_KEY=change-me-to-a-long-random-string

# 회원 명단/실적이 있는 Google Sheets 마스터 시트 ID.
# 실제 데이터는 'fKF_회원 관리' 시트에 있습니다(조회용 'fKF 정회원 이력조회'
# 시트가 IMPORTRANGE로 끌어오는 원본). 미설정 시 내장 샘플로 동작합니다.
FKF_MASTER_SHEET_ID=112_MplXH5gCAKODQyDcvymu8GsWav180zqcmq187jCQ

# 회원 명단이 있는 탭 이름.
#  - 'MDB'  : 조회 카드가 실제로 참조하는 라이브 데이터 탭(헤더 위치가 일반적이지
#             않을 수 있음 — get_all_values 헤더 행 확인 필요)
#  - '2022_print' : 헤더가 1행에 정리된 표 형태(연도 고정)
# 운영 시 현재 사용하는 정규 명단 탭으로 지정하세요.
FKF_ROSTER_TAB=MDB

# 서비스 계정 자격증명(JSON 문자열). 위 마스터 시트에 '뷰어' 이상 권한으로
# 서비스 계정 이메일을 공유해야 읽을 수 있습니다(IMPORTRANGE 아님, 직접 읽기).
# 없으면 같은 폴더의 credentials.json 파일을 사용합니다.
GOOGLE_CREDENTIALS=
