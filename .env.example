# ── fKF 정회원 포털 환경 변수 ────────────────────────────────────────────────
# 실제 값은 커밋하지 말고 배포 플랫폼의 환경 변수로 설정하세요.

# Flask 세션 서명 키 (운영에서는 반드시 임의의 긴 값으로)
SECRET_KEY=change-me-to-a-long-random-string

# 회원 명단/실적이 있는 Google Sheets 마스터 시트 ID.
# 미설정 시 내장 샘플 데이터로 동작합니다.
FKF_MASTER_SHEET_ID=

# 마스터 시트에서 회원 명단이 있는 탭 이름 (기본: 회원명단)
FKF_ROSTER_TAB=회원명단

# 서비스 계정 자격증명(JSON 문자열). 시트 읽기 권한 필요.
# 없으면 같은 폴더의 credentials.json 파일을 사용합니다.
GOOGLE_CREDENTIALS=
